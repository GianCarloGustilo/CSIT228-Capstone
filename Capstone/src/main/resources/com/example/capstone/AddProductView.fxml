<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.capstone.controller.AddProductController"
      style="-fx-background-color: #111214;
             -fx-padding: 36 32 28 32;
             -fx-min-width: 420;">

    <!-- Header -->
    <VBox spacing="4">
        <Label text="INVENTORY"
               style="-fx-font-family: 'DM Mono'; -fx-font-size: 11;
                      -fx-text-fill: #6EE7B7;"/>
        <Label text="Add / Edit Product"
               style="-fx-font-family: 'DM Serif Display';
                      -fx-font-size: 24; -fx-text-fill: #F5F4F0;"/>
    </VBox>

    <!-- Divider -->
    <Region style="-fx-background-color: rgba(255,255,255,0.08);
                   -fx-min-height: 1; -fx-max-height: 1;">
        <VBox.margin><Insets top="18" bottom="22"/></VBox.margin>
    </Region>

    <!-- Fields -->
    <VBox spacing="16">

        <!-- Name -->
        <VBox spacing="7">
            <Label text="PRODUCT NAME"
                   style="-fx-font-family: 'DM Mono'; -fx-font-size: 11;
                          -fx-text-fill: #6B7280;"/>
            <TextField fx:id="nameField" promptText="e.g. Wireless Headphones"
                       style="-fx-background-color: #1A1C1F; -fx-background-radius: 10;
                              -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 10;
                              -fx-border-width: 0.5; -fx-text-fill: #F5F4F0;
                              -fx-prompt-text-fill: #3D4048;
                              -fx-font-family: 'Outfit'; -fx-font-size: 14;
                              -fx-padding: 10 14;"/>
        </VBox>

        <!-- Description -->
        <VBox spacing="7">
            <Label text="DESCRIPTION (optional)"
                   style="-fx-font-family: 'DM Mono'; -fx-font-size: 11;
                          -fx-text-fill: #6B7280;"/>
            <TextField fx:id="descField" promptText="Short product description"
                       style="-fx-background-color: #1A1C1F; -fx-background-radius: 10;
                              -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 10;
                              -fx-border-width: 0.5; -fx-text-fill: #F5F4F0;
                              -fx-prompt-text-fill: #3D4048;
                              -fx-font-family: 'Outfit'; -fx-font-size: 14;
                              -fx-padding: 10 14;"/>
        </VBox>

        <!-- Category + Supplier row -->
        <GridPane hgap="14">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox spacing="7" GridPane.columnIndex="0">
                <Label text="CATEGORY"
                       style="-fx-font-family: 'DM Mono'; -fx-font-size: 11;
                              -fx-text-fill: #6B7280;"/>
                <ComboBox fx:id="categoryCombo" maxWidth="Infinity"
                          promptText="Select category"
                          style="-fx-background-color: #1A1C1F;
                                 -fx-border-color: rgba(255,255,255,0.10);
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-border-width: 0.5;
                                 -fx-font-family: 'Outfit'; -fx-font-size: 13;"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="1">
                <Label text="SUPPLIER"
                       style="-fx-font-family: 'DM Mono'; -fx-font-size: 11;
                              -fx-text-fill: #6B7280;"/>
                <ComboBox fx:id="supplierCombo" maxWidth="Infinity"
                          promptText="Select supplier"
                          style="-fx-background-color: #1A1C1F;
                                 -fx-border-color: rgba(255,255,255,0.10);
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-border-width: 0.5;
                                 -fx-font-family: 'Outfit'; -fx-font-size: 13;"/>
            </VBox>
        </GridPane>

        <!-- Price + Quantity + Low Stock threshold row -->
        <GridPane hgap="14">
            <columnConstraints>
                <ColumnConstraints percentWidth="34"/>
                <ColumnConstraints percentWidth="33"/>
                <ColumnConstraints percentWidth="33"/>
            </columnConstraints>

            <VBox spacing="7" GridPane.columnIndex="0">
                <Label text="PRICE (₱)"
                       style="-fx-font-family: 'DM Mono'; -fx-font-size: 11;
                              -fx-text-fill: #6B7280;"/>
                <TextField fx:id="priceField" promptText="0.00"
                           style="-fx-background-color: #1A1C1F; -fx-background-radius: 10;
                                  -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 10;
                                  -fx-border-width: 0.5; -fx-text-fill: #F5F4F0;
                                  -fx-prompt-text-fill: #3D4048;
                                  -fx-font-family: 'Outfit'; -fx-font-size: 14;
                                  -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="1">
                <Label text="QUANTITY"
                       style="-fx-font-family: 'DM Mono'; -fx-font-size: 11;
                              -fx-text-fill: #6B7280;"/>
                <TextField fx:id="quantityField" promptText="0"
                           style="-fx-background-color: #1A1C1F; -fx-background-radius: 10;
                                  -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 10;
                                  -fx-border-width: 0.5; -fx-text-fill: #F5F4F0;
                                  -fx-prompt-text-fill: #3D4048;
                                  -fx-font-family: 'Outfit'; -fx-font-size: 14;
                                  -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="2">
                <Label text="LOW STOCK ALERT"
                       style="-fx-font-family: 'DM Mono'; -fx-font-size: 11;
                              -fx-text-fill: #6B7280;"/>
                <TextField fx:id="thresholdField" promptText="10"
                           style="-fx-background-color: #1A1C1F; -fx-background-radius: 10;
                                  -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 10;
                                  -fx-border-width: 0.5; -fx-text-fill: #F5F4F0;
                                  -fx-prompt-text-fill: #3D4048;
                                  -fx-font-family: 'Outfit'; -fx-font-size: 14;
                                  -fx-padding: 10 14;"/>
            </VBox>
        </GridPane>

    </VBox>

    <!-- Actions -->
    <HBox spacing="10">
        <HBox.margin><Insets top="28"/></HBox.margin>

        <Button text="Save product" onAction="#onSave"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #6EE7B7;
                       -fx-background-radius: 10; -fx-text-fill: #0D2118;
                       -fx-font-family: 'Outfit'; -fx-font-size: 14;
                       -fx-font-weight: bold; -fx-padding: 12 0;
                       -fx-border-width: 0; -fx-cursor: hand;"/>

        <Button text="Cancel" onAction="#onCancel"
                style="-fx-background-color: transparent;
                       -fx-background-radius: 10;
                       -fx-border-color: rgba(255,255,255,0.10);
                       -fx-border-radius: 10; -fx-border-width: 0.5;
                       -fx-text-fill: #6B7280; -fx-font-family: 'Outfit';
                       -fx-font-size: 14; -fx-padding: 12 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>
